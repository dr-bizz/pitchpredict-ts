# ---------------------------------------------------------------------------
# PitchPredict — environment configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# --- Database (Neon / Postgres) --------------------------------------------
# Used by libs/db (Drizzle client + drizzle-kit) and the Next.js API routes.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- NextAuth (web) --------------------------------------------------------
# Public URL of the web app. Required by NextAuth v5.
AUTH_URL="http://localhost:3000"

# Secret used by NextAuth to encrypt its own session JWT (the browser cookie).
# Generate with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# --- Password reset --------------------------------------------------------
# HS256 secret used to sign/verify password-reset tokens.
# Generate with: openssl rand -base64 32
AUTH_RESET_SECRET="generate-with-openssl-rand-base64-32"
