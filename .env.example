# ---------------------------------------------------------------------------
# PitchPredict — environment configuration
# Copy this file to `.env` and fill in real values. Never commit `.env`.
# ---------------------------------------------------------------------------

# --- Database (Neon / Postgres) --------------------------------------------
# Used by libs/db (Drizzle client + drizzle-kit) and the Nest API.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- API (Nest) <-> Web (Next BFF) -----------------------------------------
# Base URL the Next BFF proxy + NextAuth use to reach the Nest API.
API_URL="http://localhost:3334"

# Origin the Nest API allows via CORS (the web app). Optional; defaults to
# http://localhost:3000.
WEB_ORIGIN="http://localhost:3000"

# Port the Nest API listens on. Optional; defaults to 3334.
# PORT=3334

# --- NextAuth (web) --------------------------------------------------------
# Public URL of the web app. Required by NextAuth v5.
AUTH_URL="http://localhost:3000"

# Secret used by NextAuth to encrypt its own session JWT (the browser cookie).
# Generate with: openssl rand -base64 32
AUTH_SECRET="generate-with-openssl-rand-base64-32"

# --- RS256 keypair: web signs API tokens, API verifies via JWKS ------------
# The web BFF signs an RS256 JWT with the PRIVATE key and exposes the matching
# PUBLIC key at /api/auth/jwks.json. The Nest API verifies tokens against that
# JWKS endpoint. Generate a keypair:
#   openssl genpkey -algorithm RSA -pkcs8 -out private.pem
#   openssl rsa -in private.pem -pubout -out public.pem
# Then paste the PEM contents (newlines as literal \n) below.
AUTH_JWT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
AUTH_JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----\n"

# Where the Nest API fetches the public JWK set (the web app's jwks.json route).
AUTH_JWKS_URI="http://localhost:3000/api/auth/jwks.json"

# Issuer / audience claims. Must match between the web signer and the API verifier.
AUTH_JWT_ISSUER="pitchpredict-web"
AUTH_JWT_AUDIENCE="pitchpredict-api"

# --- Password reset --------------------------------------------------------
# HS256 secret used by the API to sign/verify password-reset tokens.
# Generate with: openssl rand -base64 32
AUTH_RESET_SECRET="generate-with-openssl-rand-base64-32"
