{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "composite": true,
    "declaration": true,
    "module": "commonjs",
    "moduleResolution": "node10",
    "types": ["jest", "node"],
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "target": "es2021",
    "esModuleInterop": true
  },
  "include": [
    "jest.config.ts",
    "src/**/*.test.ts",
    "src/**/*.spec.ts",
    "src/**/*.ts",
    "src/**/*.d.ts"
  ],
  "references": [
    {
      "path": "../api/tsconfig.app.json"
    },
    {
      "path": "../../libs/db/tsconfig.lib.json"
    },
    {
      "path": "../../libs/contracts/tsconfig.lib.json"
    }
  ]
}
